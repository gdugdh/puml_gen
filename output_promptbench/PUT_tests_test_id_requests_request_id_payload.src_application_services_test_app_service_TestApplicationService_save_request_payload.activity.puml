@startuml
title src.application.services.test_app_service.TestApplicationService.save_request_payload
start

:self._require_test_dir(test_id);
:request_path = os.path.join(self._test_dir(test_id), 'requests', f'{request_id}.json');
if (not os.path.exists(request_path)) then (+)
    :await self._storage.save_json(request_path, payload);
endif
:return {'status': 'saved', 'test_id': test_id, 'request_id': request_id, 'file_path': request_path};
stop
@enduml
