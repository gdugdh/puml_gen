@startuml
title GET /api/steam_course - Получение курса USDT→RUB из DonateHub
start

:Params: no params;

:**Config** = application config;

#palegreen :GET /api/steam_course;

:**Response**;
note: A2.R2

if (**Response.Code** = HTTP 200?) then (+)
    if (**Response.Body.USD_RUB** = 0?) then (+)
        :HTTP 400 BadRequest\nwith error code **Config.ErrorCodes.InvalidSteamRate**;
        note: DigitalGoods:STM_1001
        end
    endif

    :**Response.Body**;
    stop
endif

if (**Response.Code** = HTTP 401?) then (+)
    :HTTP 401 Unauthorized;
    end
endif

:HTTP 400 BadRequest;
end

@enduml