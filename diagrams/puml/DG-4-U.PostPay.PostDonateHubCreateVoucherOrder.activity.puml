@startuml
title POST /api/vouchers/buy - Создание заказа на покупку кода пополнения в DonateHub
start

:Params: **codeId**, **count**;

:**Config** = application config;

:Build request\nwith: `code_id` = **codeId**, `count` = **count**;
note: A3.R1

#palegreen :POST /api/vouchers/buy;

:**Response**;
note: A3.R2

if (**Response.Code** = HTTP 200?) then (+)
    :**Response.Body**;
    stop
endif

if (**Response.Code** = HTTP 401?) then (+)
    :HTTP 401 Unauthorized;
    end
endif

if (**Response.Code** = HTTP 400 AND\n**Response.Body.error_message** = **Config.DonatehubErrorsMessages.InsufficientFunds**?) then (+)
    :HTTP 400 BadRequest\nwith error code **Config.ErrorCodes.InsufficientFunds**;
    note
        Недостаточно средств на балансе.
        ====
        DigitalGoods:STM_1004
    end note
    end
endif

:HTTP 400 BadRequest;
end

@enduml