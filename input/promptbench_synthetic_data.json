    {
      "function_id": "src.application.services.test_app_service.TestApplicationService.create_request",
      "name": "create_request",
      "kind": "service_entry",
      "module": "src.application.services.test_app_service",
      "file": "projects_for_test/PromptBench/src/application/services/test_app_service.py",
      "signature": "async def create_request(self, test_id: str, payload: dict[str, Any], name: str | None) -> dict[str, Any]",
      "steps": [
        {
          "kind": "call",
          "source": "test_dir = self._require_test_dir(test_id)"
        },
        {
          "kind": "assign",
          "source": "requests_dir = os.path.join(test_dir, 'requests')"
        },
        {
          "kind": "call",
          "source": "os.makedirs(requests_dir, exist_ok=True)"
        },
        {
          "kind": "call",
          "source": "rid = self._next_request_id(requests_dir, name)"
        },
        {
          "kind": "assign",
          "source": "file_path = os.path.join(requests_dir, f'{rid}.json')"
        },
        {
          "kind": "call",
          "source": "await self._storage.save_json(file_path, payload)"
        },
        {
          "kind": "return",
          "source": "return {'id': rid, 'test_id': test_id, 'file_path': file_path, 'status': 'pending'}"
        }
      ]
    },
    {
      "function_id": "src.application.services.test_app_service.TestApplicationService.delete_test",
      "name": "delete_test",
      "kind": "service_entry",
