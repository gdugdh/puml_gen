      "file": "projects_for_test/PromptBench/src/application/services/gateway_app_service.py",
      "signature": "async def stream_batch_sse(self, items: list[GatewayBatchItem]) -> AsyncIterator[str]",
      "steps": [
        {
          "kind": "loop",
          "source": "for item in items"
        },
        {
          "kind": "call",
          "source": "resp = await self._llm.send(dict(item.payload))"
        },
        {
          "kind": "assign",
          "source": "data = {'id': item.id, 'payload': resp}"
        },
        {
          "kind": "except",
          "source": "except Exception as e:"
        },
        {
          "kind": "assign",
          "source": "data = {'id': item.id, 'error': {'message': 'Orchestrator request failed', 'details': str(e)}}"
        },
        {
          "kind": "yield",
          "source": "yield f\"data: {json.dumps(data, ensure_ascii=False)}\\n\\n\""
        },
        {
          "kind": "yield",
          "source": "yield 'data: [DONE]\\n\\n'"
        }
      ]
    }
