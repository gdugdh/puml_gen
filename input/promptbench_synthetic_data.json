      "function_id": "src.application.services.test_app_service.TestApplicationService.create_test",
      "name": "create_test",
      "kind": "service_entry",
      "module": "src.application.services.test_app_service",
      "file": "projects_for_test/PromptBench/src/application/services/test_app_service.py",
      "signature": "def create_test(self, name: str) -> dict[str, Any]",
      "steps": [
        {
          "kind": "call",
          "source": "os.makedirs(settings.STORAGE, exist_ok=True)"
        },
        {
          "kind": "call",
          "source": "test_id = unique_test_id(settings.STORAGE, name)"
        },
        {
          "kind": "assign",
          "source": "test_dir = self._test_dir(test_id)"
        },
        {
          "kind": "call",
          "source": "os.makedirs(os.path.join(test_dir, 'requests'), exist_ok=True)"
        },
        {
          "kind": "call",
          "source": "os.makedirs(os.path.join(test_dir, 'responses'), exist_ok=True)"
        },
        {
          "kind": "return",
          "source": "return {'id': test_id, 'name': test_id, 'status': get_test_status(test_id), 'requests': self._build_requests_view(test_id)}"
        }
      ]
    },
